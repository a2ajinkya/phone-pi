#!/usr/bin/env bash
# ingest-parse: Parse a document to JSON (structured text with positions)
# Usage: ingest-parse <file> [pages]
#   pages: optional page range like "1-5,10,15-20"
# Output: JSON to stdout

set -euo pipefail

FILE="${1:?Usage: ingest-parse <file> [pages]}"
PAGES="${2:-}"

if [ ! -f "$FILE" ]; then
  echo "Error: file not found: $FILE" >&2
  exit 1
fi

CMD=(lit parse "$FILE" --format json -q)

if [ -n "$PAGES" ]; then
  CMD+=(--target-pages "$PAGES")
fi

exec "${CMD[@]}"